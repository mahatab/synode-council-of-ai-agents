{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "about"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "opener:default"
  ]
}
